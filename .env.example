# ============================================================
# .env - Variables de entorno del Backend Despachos
# IMPORTANTE: NO subir este archivo al repositorio con datos reales
# Copiar como .env y completar con los valores reales
# ============================================================

# Base de Datos
DB_ENDPOINT=mysql
DB_PORT=3306
DB_NAME=despachos_db
DB_USERNAME=appuser
DB_PASSWORD=CambiarEstaPassword123!

# Java
JAVA_OPTS=-Xms256m -Xmx512m
